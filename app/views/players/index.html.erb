<div class="players-page">
  <h1>Players</h1>

  <section class="players-form-section">
    <h2>Add Player</h2>

    <%= form_with model: Player.new, url: players_path, html: { class: "player-form" } do |f| %>
      <%= f.text_field :name, placeholder: "Enter player name" %>
      <%= f.submit "Add" %>
    <% end %>
  </section>

  <section class="players-list-section">
    <ul class="players-list">
      <% @players.each do |player| %>
        <li class="player-row">
          <span class="player-details">
            <%= player.name %>
            (Wins: <%= player.wins_count %>, Losses: <%= player.losses_count %>)
          </span>

          <%= button_to "Delete", player_path(player), method: :delete, class: "player-delete-button" %>
        </li>
      <% end %>
    </ul>
  </section>
</div>
